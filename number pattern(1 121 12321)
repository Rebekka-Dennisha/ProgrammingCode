Write a program to print pattern of numbers as below:
1
121
12321

Coding:



#include<stdio.h>
int main(){
    int row,col,i,j,k;
    scanf("%d %d",&row,&col); //getting input
    for(i=0;i<row;i++){
        for(j=0;j<=i;j++){
            printf("%d",j+1);  // for loop to print increment number
        }
        for(int k=j-1;k>0;k--){
            printf("%d",k);   // for loop to print decrement number
        }
        printf("\n");
    }
}
